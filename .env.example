# =============================================================================
# RAZORPAY UPI TELEGRAM BOT — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains secrets.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# =============================================================================
# SECTION 1: TELEGRAM
# =============================================================================

# Your bot token from @BotFather — REQUIRED
TELEGRAM_BOT_TOKEN=

# Public HTTPS URL for Telegram to push updates (webhook mode)
# Format: https://yourdomain.com/api/telegram/webhook
# Leave blank for long-polling mode (works locally, no public URL needed)
TELEGRAM_WEBHOOK_URL=

# =============================================================================
# SECTION 2: RAZORPAY KEYS
# =============================================================================

# ── Test keys (sandbox — no real money) — REQUIRED ────────────────────────────
# Get from: Razorpay Dashboard → Settings → API Keys → Test Mode
RAZORPAY_KEY_ID=rzp_test_
RAZORPAY_KEY_SECRET=

# ── Live keys (real UPI payments via /real command) — OPTIONAL ─────────────────
# Get from: Razorpay Dashboard → Settings → API Keys → Live Mode
# Leave blank to disable the /real command
RAZORPAY_LIVE_KEY_ID=rzp_live_
RAZORPAY_LIVE_KEY_SECRET=

# ── Webhook secret — REQUIRED IN PRODUCTION ───────────────────────────────────
# Generate: openssl rand -hex 32
# Paste the same string in: Razorpay Dashboard → Settings → Webhooks → Secret
# Razorpay dashboard events to enable:
#   ✅ qr_code.credited    (primary UPI payment detection)
#   ✅ payment.captured    (live mode backup detection)
#   ✅ payment_link.paid   (test mode Pay-on-Web checkout)
RAZORPAY_WEBHOOK_SECRET=

# =============================================================================
# SECTION 3: BRANDING
# =============================================================================

# Your business or brand name
# Shown in: QR code name, /start message, payment description, UPI pn= field
# Default: My Store
BRAND_NAME=My Store

# What you are selling — product or service name
# Shown in: QR description, payment link, payment confirmation
# Default: Payment
PRODUCT_NAME=Payment

# Short tagline shown below BRAND_NAME in /start
# E.g. "Premium digital products delivered instantly"
# Leave blank for no tagline
BOT_DESCRIPTION=

# =============================================================================
# SECTION 4: POST-PAYMENT MESSAGE (product delivery)
# =============================================================================
#
# Message sent to buyer IMMEDIATELY after payment is confirmed.
# This is where you deliver your product — key, link, instructions.
#
# Placeholders (auto-replaced):
#   {amount}      — formatted rupee amount, e.g. ₹500.00
#   {payment_id}  — Razorpay payment ID, e.g. pay_AbCd1234XxYy
#   {mode}        — payment mode: TEST or LIVE
#
# HTML supported: <b>bold</b>  <i>italic</i>  <code>monospace</code>
# Use \n for line breaks in the message.
#
# Examples:
#   PAYMENT_SUCCESS_MESSAGE=🔑 License key: XYZ-1234-ABCD
#   PAYMENT_SUCCESS_MESSAGE=📦 Download: https://yoursite.com/dl?ref={payment_id}
#   PAYMENT_SUCCESS_MESSAGE=✅ Thanks for {amount}! WhatsApp +91-9999999999 with ID: {payment_id}
#   PAYMENT_SUCCESS_MESSAGE=🎉 Access granted!\n\nKey: <code>ABC-XYZ</code>\nExpiry: 1 year
#
# Leave blank to show only the standard payment confirmation.
PAYMENT_SUCCESS_MESSAGE=

# =============================================================================
# SECTION 5: ADMIN NOTIFICATIONS
# =============================================================================

# Telegram chat ID of the admin/seller.
# If set, the bot sends a notification to this chat on every confirmed payment.
# Get your ID: message @userinfobot on Telegram → it shows your numeric ID
# E.g. ADMIN_CHAT_ID=123456789
ADMIN_CHAT_ID=

# =============================================================================
# SECTION 6: SUPPORT & OPEN SOURCE
# =============================================================================

# Shown in /help and /start as the support contact.
# Use a Telegram username: @YourSupportUsername
# Or a WhatsApp link:      https://wa.me/91XXXXXXXXXX
# Leave blank to hide the support line.
SUPPORT_CONTACT=

# Link to the GitHub repo — shown in /about
# Leave blank to hide the GitHub line.
GITHUB_URL=https://github.com/vishwajeetcoderr-dev/tg-upi-live

# =============================================================================
# SECTION 7: FEATURE FLAGS
# =============================================================================

# Set to true to hide the /test command (production: accept only /real payments)
# Default: false
DISABLE_TEST_MODE=false

# =============================================================================
# SECTION 8: AMOUNT LIMITS
# =============================================================================
# All values in PAISE — multiply rupee amount × 100
# ₹1=100  ₹10=1000  ₹100=10000  ₹500=50000  ₹1000=100000

# Test mode limits (default: ₹1 – ₹5,00,000)
MIN_AMOUNT_TEST=100
MAX_AMOUNT_TEST=50000000

# Live (real) mode limits (default: ₹1 – ₹1,00,000)
MIN_AMOUNT_REAL=100
MAX_AMOUNT_REAL=10000000

# =============================================================================
# SECTION 9: SESSION SETTINGS
# =============================================================================

# How long the QR stays active before auto-expiring (minutes, minimum: 2)
# Both the bot session AND the Razorpay QR expire together at this time.
# Default: 2
SESSION_TIMEOUT_MINUTES=2

# =============================================================================
# SECTION 10: CUSTOM MESSAGES (advanced)
# =============================================================================

# Fully replaces the /start command message if set.
# Placeholder: {name} → user's Telegram first name
# HTML supported: <b>bold</b>  <i>italic</i>  <code>mono</code>
# Leave blank to use the auto-generated welcome message (recommended).
WELCOME_MESSAGE=

# =============================================================================
# SECTION 11: DIRECT UPI QR (alternative to Razorpay QR API)
# =============================================================================
#
# Your UPI VPA / UPI ID (e.g. yourname@upi, merchant@okicici)
#
# If set:   Bot generates plain upi:// QR — opens UPI app directly (no Razorpay QR API)
# If blank: Bot uses Razorpay fixed-amount QR (RECOMMENDED — amount cannot be changed by user)
#
# ⚠️  WARNING: With direct UPI QR, users CAN manually edit the amount in their UPI app.
# ⚠️  Razorpay QR (leave this blank) locks the amount — safer for commerce.
MERCHANT_UPI_ID=
